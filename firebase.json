                        "cleanUrls":  true,
                        "ignore":  [
                                       "firebase.json",
                                       "**/.*",
                                       "**/node_modules/**"
                                   ],
                        "rewrites":  [
                                         {
                                             "regex":  "^/(.+)/__next\\.(.+)\\.__PAGE__\\.txt$",
                                             "destination":  "/:1/__next.:2/__PAGE__.txt"
                                         }
                                     ],
                        "headers":  [
                                        {
                                            "source":  "/",
                                            "headers":  [
                                                            {
                                                                "key":  "Link",
