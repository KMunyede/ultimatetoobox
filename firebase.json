{
    "hosting":  [
                    {
                        "target":  "hilmost-toolbox",
                        "public":  "apps/hilmost_toolbox_web/out",
                        "cleanUrls":  true,
                        "ignore":  [
                                       "firebase.json",
                                       "**/.*",
                                       "**/node_modules/**"
                                   ],
                        "rewrites":  [
                                         {
                                             "regex":  "^/(.+)/__next\\.(.+)\\.__PAGE__\\.txt$",
                                             "destination":  "/$1/__next.$2/__PAGE__.txt"
                                         }
                                     ],
                        "headers":  [
                                        {
                                            "source":  "**/*.@(css|woff2|wasm)",
                                            "headers":  [
                                                            {
                                                                "key":  "Cache-Control",
                                                                "value":  "max-age=31536000, immutable"
                                                            }
                                                        ]
                                        },
                                        {
                                            "source":  "**/*.@(html|js)",
                                            "headers":  [
                                                            {
                                                                "key":  "Cache-Control",
                                                                "value":  "no-cache, no-store, must-revalidate"
                                                            }
                                                        ]
                                        },
                                        {
                                            "source":  "**",
                                            "headers":  [
                                                            {
                                                                "key":  "X-Frame-Options",
                                                                "value":  "SAMEORIGIN"
                                                            }
                                                        ]
                                        }
                                    ]
                    },
                    {
                        "target":  "hilmost-toolbox-staging",
